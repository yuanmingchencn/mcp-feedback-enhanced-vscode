{
  "name": "mcp-feedback-enhanced",
  "displayName": "MCP Feedback Enhanced",
  "description": "Interactive feedback collection for AI assistants with multi-session tabs",
  "version": "2.0.0",
  "publisher": "mcp-feedback",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuanmingchencn/mcp-feedback-enhanced-vscode"
  },
  "homepage": "https://github.com/yuanmingchencn/mcp-feedback-enhanced-vscode#readme",
  "bugs": {
    "url": "https://github.com/yuanmingchencn/mcp-feedback-enhanced-vscode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "mcp",
    "feedback",
    "ai",
    "cursor",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcp-feedback-enhanced",
          "title": "MCP Feedback Enhanced",
          "icon": "resources/icon.svg"
        }
      ],
      "panel": [
        {
          "id": "mcp-feedback-enhanced-bottom",
          "title": "MCP Feedback Enhanced",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "mcp-feedback-enhanced": [
        {
          "type": "webview",
          "id": "mcp-feedback-enhanced.feedbackPanel",
          "name": "Feedback",
          "visibility": "hidden",
          "when": "config.mcp-feedback-enhanced.showInSidebar"
        }
      ],
      "mcp-feedback-enhanced-bottom": [
        {
          "type": "webview",
          "id": "mcp-feedback-enhanced.feedbackPanelBottom",
          "name": "MCP Feedback Enhanced",
          "visibility": "visible",
          "when": "config.mcp-feedback-enhanced.showInBottomPanel"
        }
      ]
    },
    "configuration": {
      "title": "MCP Feedback Enhanced",
      "properties": {
        "mcp-feedback-enhanced.showInSidebar": {
          "type": "boolean",
          "default": false,
          "description": "Show MCP Feedback panel in the left sidebar"
        },
        "mcp-feedback-enhanced.showInBottomPanel": {
          "type": "boolean",
          "default": true,
          "description": "Show MCP Feedback panel in the bottom panel"
        }
      }
    },
    "commands": [
      {
        "command": "mcp-feedback-enhanced.openPanel",
        "title": "MCP Feedback Enhanced: Open in Sidebar",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "mcp-feedback-enhanced.openInEditor",
        "title": "MCP Feedback Enhanced: Open in Editor (Tab)",
        "icon": "$(window)"
      },
      {
        "command": "mcp-feedback-enhanced.openInBottom",
        "title": "MCP Feedback Enhanced: Open in Bottom Panel",
        "icon": "$(panel)"
      },
      {
        "command": "mcp-feedback-enhanced.reconnect",
        "title": "MCP Feedback Enhanced: Reconnect to Server"
      },
      {
        "command": "mcp-feedback-enhanced.focusInput",
        "title": "MCP Feedback Enhanced: Focus Input Field"
      },
      {
        "command": "mcp-feedback-enhanced.forceReset",
        "title": "MCP Feedback Enhanced: Force Reset (Restart Server)"
      },
      {
        "command": "mcp-feedback-enhanced.showStatus",
        "title": "MCP Feedback Enhanced: Show Status"
      }
    ],
    "keybindings": [
      {
        "command": "mcp-feedback-enhanced.openPanel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "mcp-feedback-enhanced.focusInput",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "cd mcp-server && npm run build && cd .. && node scripts/generate-webview.js --prod && node scripts/validate-build.js && npm run esbuild-base -- --minify && npm run verify",
    "compile": "cd mcp-server && npm run build && cd .. && tsc -p ./ && node scripts/generate-webview.js && node scripts/validate-build.js && npm run esbuild && npm run verify",
    "verify": "node -e \"const h=require('fs').readFileSync('out/webview/panel.html','utf8');const e=require('fs').readFileSync('out/extension.js','utf8');const checks=[];if(!h.includes('{{SERVER_URL}}'))checks.push('Missing SERVER_URL placeholder');if(!e.includes('retainContextWhenHidden:!1')&&!e.includes('retainContextWhenHidden: false'))checks.push('retainContextWhenHidden should be false');if(!e.includes('panel.html'))checks.push('Missing panel.html reference');if(checks.length){console.error('ERRORS:',checks.join(', '));process.exit(1)}console.log('Verify OK')\"",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  }
}
